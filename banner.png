<svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="1280" height="640" viewBox="0 0 1280 640">
  <!-- Background matching logo edges -->
  <rect width="1280" height="640" fill="#111827"/>

  <!-- Logo image - centered, large -->
  <image x="290" y="-40" width="700" height="700" href="data:image/jpeg;base64," preserveAspectRatio="xMidYMid meet"/>

  <!-- Subtle brand text at bottom -->
  <text x="640" y="590" text-anchor="middle" fill="rgba(255,255,255,0.15)" font-family="'SF Pro Display','Helvetica Neue',Arial,sans-serif" font-size="28" font-weight="600" letter-spacing="12">IOTECHS</text>
</svg>
